# ============================================================
# IEEPA Trade Claim Sourcing System — Environment Variables
# Copy this file to .env.local (web) and .env (worker)
# NEVER commit actual secrets to version control
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Email (Resend) ────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM_ADDRESS=claims@yourdomain.com
EMAIL_FROM_NAME=IEEPA Claims Fund
EMAIL_REPLY_TO=team@yourdomain.com
ADMIN_EMAIL=team@yourdomain.com

# ── Contact Enrichment (Apollo.io) ───────────────────────────
# Get from: https://developer.apollo.io
APOLLO_API_KEY=your-apollo-api-key

# ── Federal Register API ──────────────────────────────────────
# Public API — no key required, but set base URL
FEDERAL_REGISTER_API_BASE=https://www.federalregister.gov/api/v1

# ── CourtListener (PACER/CIT cases) ──────────────────────────
# Get from: https://www.courtlistener.com/help/api/rest/#authentication
COURTLISTENER_API_KEY=your-courtlistener-token

# ── News API ─────────────────────────────────────────────────
# Get from: https://newsapi.org/register
NEWSAPI_KEY=your-newsapi-key

# ── SEC EDGAR ─────────────────────────────────────────────────
# No key required — provide a descriptive User-Agent per SEC guidelines
# Format: "Company/App contact@email.com"
EDGAR_USER_AGENT=IEEPAFund/1.0 admin@yourdomain.com

# ── Slack Notifications ───────────────────────────────────────
# Create an Incoming Webhook at: https://api.slack.com/apps
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# ── Analytics (PostHog) ───────────────────────────────────────
# Get from: https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Redis (BullMQ) ────────────────────────────────────────────
# Local dev: redis://localhost:6379
# Production: use Redis Cloud or Upstash
REDIS_URL=redis://localhost:6379

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://yourdomain.com

# ── Email Sending Domain ─────────────────────────────────────
# The domain from which outreach emails are sent.
# Must have SPF, DKIM, DMARC configured (see README.md).
OUTREACH_SENDING_DOMAIN=mail.yourdomain.com

# ── Outreach Rate Limiting ────────────────────────────────────
OUTREACH_MAX_PER_HOUR=50
OUTREACH_DAILY_LIMIT=500
