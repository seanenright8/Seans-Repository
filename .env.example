# ── SMTP / Email Settings ─────────────────────────────────────────────
# For Gmail: use smtp.gmail.com / 587 and an App Password
# (https://support.google.com/accounts/answer/185833)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password

# Sender address (defaults to SMTP_USER if omitted)
FROM_EMAIL=you@gmail.com

# Where to send the alerts
TO_EMAIL=you@gmail.com

# ── NewsAPI ───────────────────────────────────────────────────────────
# Free key from https://newsapi.org/register
NEWSAPI_KEY=your-newsapi-key

# ── Alert Tuning ──────────────────────────────────────────────────────
# Percentage threshold (negative number). Default: -10.0
DROP_THRESHOLD=-10.0

# Time to run the daily check (24-hour HH:MM). Default: 16:30 (after market close)
CHECK_TIME=16:30

# ── IEEPA Claims Scanner ───────────────────────────────────────────────
# Anthropic API key — get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key

# Directory to store JSON + Markdown reports. Default: ieepa_reports
IEEPA_OUTPUT_DIR=ieepa_reports

# Time to run the daily IEEPA scan (24-hour HH:MM). Default: 08:00
IEEPA_CHECK_TIME=08:00

# Maximum number of claims to surface per run. Default: 20
IEEPA_MAX_CLAIMS=20

# Optional: extra pipe-separated search queries beyond the defaults
# Example: "IEEPA China sanctions 2025|IEEPA Russia oil challenge"
IEEPA_EXTRA_QUERIES=
