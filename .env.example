# ── SMTP / Email Settings ─────────────────────────────────────────────
# For Gmail: use smtp.gmail.com / 587 and an App Password
# (https://support.google.com/accounts/answer/185833)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password

# Sender address (defaults to SMTP_USER if omitted)
FROM_EMAIL=you@gmail.com

# Where to send the alerts
TO_EMAIL=you@gmail.com

# ── NewsAPI ───────────────────────────────────────────────────────────
# Free key from https://newsapi.org/register
NEWSAPI_KEY=your-newsapi-key

# ── Alert Tuning ──────────────────────────────────────────────────────
# Percentage threshold (negative number). Default: -10.0
DROP_THRESHOLD=-10.0

# Time to run the daily check (24-hour HH:MM). Default: 16:30 (after market close)
CHECK_TIME=16:30
